// Bu kuralları Firebase Console > Firestore Database > Kurallar (Rules)
// sekmesine yapıştırıp "Yayınla" (Publish) demeniz gerekir — bu dosya
// otomatik olarak Firebase'e yüklenmez.
//
// GÜNCELLEME: Uygulama artık kullanıcı adı/şifre ile giriş yaptırıyor
// (bkz. js/auth.js), bu yüzden kurallar da buna göre sıkılaştırıldı:
// - Giriş yapmamış hiç kimse HİÇBİR VERİYİ okuyup yazamaz.
// - oy_kullanicilar ve oy_roller (hesap/yetki tanımları): sadece admin yazabilir.
// - oy_kullaniciIstatistikleri: herkes SADECE KENDİ istatistik belgesini
//   yazabilir (increment için gerekli), okuma sadece admin'e açık.
//
// ============================================================================
// SERVIS YERLEŞIM EDITÖRÜ - Ek Kurallar
// ============================================================================
//
// Servis yerleşim verisi okuma-yazma:
// - oy_servisler: Herkes okur, giriş yapmışlar düzenler
// - oy_ogrenciler: Herkes okur (öğrenci ataması için)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function girisYapmis() {
      return request.auth != null;
    }
    
    function kendiBelgemVarMi() {
      return exists(/databases/$(database)/documents/oy_kullanicilar/$(request.auth.uid));
    }
    
    function adminMi() {
      return girisYapmis() && kendiBelgemVarMi()
        && get(/databases/$(database)/documents/oy_kullanicilar/$(request.auth.uid)).data.admin == true;
    }

    // Çağıranın KENDİ öğretmen kaydının ID'si (oy_kullanicilar/{uid}.bagliOgretmenId) —
    // yıllık plan seçim/not belgeleri Auth UID'i değil bu ID'yi kullanıyor.
    function kendiOgretmenIdsi() {
      return kendiBelgemVarMi()
        ? get(/databases/$(database)/documents/oy_kullanicilar/$(request.auth.uid)).data.bagliOgretmenId
        : null;
    }

    // ========== VARSAYILAN KURAL ==========
    // Varsayılan: sadece giriş yapmış (ve uygulamada hesabı olan) kullanıcılar
    // okuyup yazabilir.
    match /{document=**} {
      allow read, write: if girisYapmis();
    }

    // ========== KULLANıCı KAYITLARI ==========
    // Hesap kayıtları: herkes okuyabilir (giriş kontrolü/isim gösterimi için
    // gerekli) ama SADECE admin oluşturabilir/düzenleyebilir/silebilir.
    match /oy_kullanicilar/{uid} {
      allow read: if girisYapmis();
      allow write: if adminMi();
    }

    // ========== ROLLER ==========
    // Roller (yetki tanımları): sadece admin değiştirebilir.
    match /oy_roller/{id} {
      allow read: if girisYapmis();
      allow write: if adminMi();
    }

    // ========== KULLANıCı İSTATİSTİKLERİ ==========
    // Kullanıcı istatistikleri: herkes SADECE KENDİ belgesini yazabilir
    // (başkasının sayaçlarını değiştiremez), okuma sadece admin'e açık.
    match /oy_kullaniciIstatistikleri/{uid} {
      allow read: if adminMi() || (girisYapmis() && request.auth.uid == uid);
      allow write: if girisYapmis() && request.auth.uid == uid;
    }

    // ========== SERVIS YERLEŞIM EDITÖRÜ KUALLARI ==========
    
    // Servis kayıtları: herkes okuyabilir, giriş yapmışlar düzenleyebilir
    match /oy_servisler/{servisId} {
      allow read: if girisYapmis();
      allow create, update, delete: if girisYapmis();
    }

    // Öğrenci kayıtları: herkes okuyabilir (öğrenci ataması için)
    match /oy_ogrenciler/{ogrenciId} {
      allow read: if girisYapmis();
      allow create, update, delete: if girisYapmis();
    }

    // ========== YILLIK PLAN ==========
    // Başlık havuzu + plan tanımları (içerik): herkes okur, sadece admin yazar.
    match /oy_yillikPlanBasliklari/{id} {
      allow read: if girisYapmis();
      allow write: if adminMi();
    }
    match /oy_yillikPlanTanimlari/{id} {
      allow read: if girisYapmis();
      allow create, delete: if adminMi();
      // İçerik (dersAdi/seviye/sutunlar/satirlar/egitimOgretimYili) sadece
      // admin değiştirebilir — ama sütun genişliği/yazı boyutu/imza tarihi
      // birer YAZDIRMA TERCİHİDİR, plan içeriğini değiştirmez, bu yüzden
      // Görüntüle yetkili herkes bu ÜÇ alanı güncelleyebilsin diye ayrıca
      // serbest bırakıldı (bkz. yillik-plan.service.js → goruntuAyarlariniKaydet).
      allow update: if adminMi()
        || (girisYapmis() && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['sutunGenislikleri', 'fontBoyutuPx', 'imzaTarihi', 'satirlar', 'okulAdiManuel']));
    }
    // Öğretmenin "hangi planı takip ediyorum" seçimi: belge ID = kendi
    // ÖĞRETMEN kaydı ID'si (bkz. kendiOgretmenIdsi()) — Auth UID değil.
    // Herkes okuyabilir (başkasının seçimini görmek zararsız), ama SADECE
    // kendi belgesini oluşturabilir/güncelleyebilir — silme kapalı (seçim
    // listesi boşaltılarak güncellenir, belge silinmez).
    match /oy_ogretmenYillikPlanSecimleri/{ogretmenId} {
      allow read: if girisYapmis();
      allow create, update: if girisYapmis() && kendiOgretmenIdsi() == ogretmenId;
      allow delete: if false;
    }
    // Haftalık kişisel notlar: belge ID = `${ogretmenId}_${planId}` — SADECE
    // kendi öğretmen ID'siyle başlayan belgeyi oluşturabilir/güncelleyebilir.
    match /oy_yillikPlanNotlari/{docId} {
      allow read: if girisYapmis();
      allow create, update: if girisYapmis() && kendiOgretmenIdsi() == docId.split('_')[0];
      allow delete: if false;
    }

    // Akademik takvim posteri: herkes görebilir, sadece admin değiştirebilir.
    match /oy_akademikTakvim/{id} {
      allow read: if girisYapmis();
      allow write: if adminMi();
    }
  }
}
