// Bu kuralları Firebase Console > Firestore Database > Kurallar (Rules)
// sekmesine yapıştırıp "Yayınla" (Publish) demeniz gerekir — bu dosya
// otomatik olarak Firebase'e yüklenmez.
//
// NOT: Giriş ekranı kaldırıldığı (bkz. js/auth.js) için bu kurallar artık
// herkese açık okuma/yazma izni veriyor. Güvenlik, uygulamanın adresinin
// genel olarak paylaşılmamasına bağlıdır. Eğer ileride şifreli girişe
// dönerseniz, alttaki satırı "if request.auth != null;" ile değiştirip
// js/auth.js'i de buna göre güncellemeniz gerekir.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
