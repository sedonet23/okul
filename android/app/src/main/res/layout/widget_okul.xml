<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Okul adı - tüm sayfalarda sabit üst şerit -->
    <TextView
        android:id="@+id/widget_okul_adi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Okul Yönetim Paneli"
        android:textColor="#CCE8E8"
        android:textSize="9sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <!-- Kaydırmalı sayfa yığını: Etkinlikler / Notlarım / Nöbetçiler / Haberler -->
    <StackView
        android:id="@+id/widget_stack"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:loopViews="true" />

</LinearLayout>
