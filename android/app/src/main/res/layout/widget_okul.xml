<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Okul adı + yenile butonu - tüm sayfalarda sabit üst şerit -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/widget_okul_adi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Okul Yönetim Paneli"
            android:textColor="#CCE8E8"
            android:textSize="9sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/btn_yenile"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="🔄"
            android:textSize="11sp" />
    </LinearLayout>

    <!--
      4 sayfa burada ÜST ÜSTE (FrameLayout) durur, aynı anda sadece biri
      "visible" olur, diğerleri "gone". <include> KULLANILMIYOR — bazı
      launcher'larda (MIUI) App Widget RemoteViews inflate sürecinde
      <include> etiketinin kendisi güvenilir çalışmayıp widget'ın tamamen
      yüklenememesine ("Araç yüklenemiyor") sebep olabiliyor. Bu yüzden her
      sayfanın tüm içeriği doğrudan (include olmadan) buraya gömülü.
    -->
    <FrameLayout
        android:id="@+id/widget_sayfa_alani"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/root_etkinlikler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/widget_page_opaque_bg"
            android:padding="10dp">
                <LinearLayout
                    android:id="@+id/header_etkinlikler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/title_etkinlikler"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ETKİNLİKLER"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/dots_etkinlikler"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Haftalık takvim satırı + hafta değiştirici oklar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/btn_hafta_onceki"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:gravity="center"
                        android:text="◀"
                        android:textColor="#ABDEDE"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                    <!-- Gün 0 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal0_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal0_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Gün 1 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal1_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal1_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Gün 2 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal2_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal2_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Gün 3 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal3_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal3_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Gün 4 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal4_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal4_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Gün 5 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal5_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal5_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Gün 6 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/cal6_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#ABDEDE" android:textSize="8sp" />
                        <TextView android:id="@+id/cal6_date" android:layout_width="20dp" android:layout_height="20dp" android:gravity="center" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_hafta_sonraki"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:gravity="center"
                        android:text="▶"
                        android:textColor="#ABDEDE"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Etkinlik listesi + Saat/Hava kartı -->
                <LinearLayout
                    android:id="@+id/content_row_etkinlikler"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/etkinlik_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="86dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/widget_info_card_bg"
                        android:padding="8dp">

                        <TextClock
                            android:id="@+id/widget_clock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:format12Hour="HH:mm"
                            android:format24Hour="HH:mm"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextClock
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:format12Hour="d MMM"
                            android:format24Hour="d MMM"
                            android:textColor="#CCFFFFFF"
                            android:textSize="9sp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#26FFFFFF"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/weather_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:text="⛅" />

                        <TextView
                            android:id="@+id/weather_temp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:text="--°" />

                        <TextView
                            android:id="@+id/weather_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#B8FFFFFF"
                            android:textSize="8sp"
                            android:text="—" />
                    </LinearLayout>
                </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/root_notlar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/widget_page_opaque_bg"
            android:padding="10dp">
                <LinearLayout
                    android:id="@+id/header_notlar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/title_notlar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NOTLARIM"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/dots_notlar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/notlar_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/notlar_bos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#B8FFFFFF"
                    android:textSize="11sp"
                    android:paddingTop="20dp"
                    android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/root_nobet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/widget_page_opaque_bg"
            android:padding="10dp">
                <LinearLayout
                    android:id="@+id/header_nobet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/title_nobet"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NÖBETÇİLER"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/dots_nobet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nobet_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/nobet_bos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#B8FFFFFF"
                    android:textSize="11sp"
                    android:paddingTop="20dp"
                    android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/root_haberler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/widget_page_opaque_bg"
            android:padding="10dp">
                <LinearLayout
                    android:id="@+id/header_haberler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/title_haberler"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HABERLER"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/dots_haberler"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/haberler_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/haberler_bos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#B8FFFFFF"
                    android:textSize="11sp"
                    android:paddingTop="20dp"
                    android:visibility="gone" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
