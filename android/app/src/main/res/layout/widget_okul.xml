<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Okul adı - tüm sayfalarda sabit üst şerit -->
    <TextView
        android:id="@+id/widget_okul_adi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Okul Yönetim Paneli"
        android:textColor="#CCE8E8"
        android:textSize="9sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <!--
      4 sayfa burada ÜST ÜSTE (FrameLayout) durur, aynı anda sadece biri
      "visible" olur, diğerleri "gone". Sayfa değişimi KAYDIRMA ile değil
      DOKUNMA ile olur (bkz. OkulWidget.java) — bu yöntem StackView'dan
      farklı olarak MIUI/Xiaomi dahil TÜM launcher'larda güvenilir çalışır.
    -->
    <FrameLayout
        android:id="@+id/widget_sayfa_alani"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include
            android:id="@+id/wrap_etkinlikler"
            layout="@layout/widget_page_etkinlikler" />

        <include
            android:id="@+id/wrap_notlar"
            layout="@layout/widget_page_notlar" />

        <include
            android:id="@+id/wrap_nobet"
            layout="@layout/widget_page_nobet" />

        <include
            android:id="@+id/wrap_haberler"
            layout="@layout/widget_page_haberler" />
    </FrameLayout>

</LinearLayout>
