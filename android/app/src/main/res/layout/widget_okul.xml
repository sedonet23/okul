<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Okul adı - tüm sayfalarda sabit üst şerit -->
    <TextView
        android:id="@+id/widget_okul_adi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Okul Yönetim Paneli"
        android:textColor="#CCE8E8"
        android:textSize="9sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <!--
      4 sayfa burada ÜST ÜSTE (FrameLayout) durur, aynı anda sadece biri
      "visible" olur, diğerleri "gone". Her sayfanın kök layout'u KENDİ
      benzersiz id'sini taşıyor (root_etkinlikler / root_notlar / root_nobet /
      root_haberler) — <include android:id=...> ile id override etmeye
      GÜVENİLMİYOR çünkü bazı launcher'larda (MIUI) RemoteViews inflate
      sırasında bu override güvenilir çalışmayıp widget'ın tamamen
      yüklenememesine ("Araç yüklenemiyor") sebep olabiliyor.
    -->
    <FrameLayout
        android:id="@+id/widget_sayfa_alani"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include layout="@layout/widget_page_etkinlikler" />
        <include layout="@layout/widget_page_notlar" />
        <include layout="@layout/widget_page_nobet" />
        <include layout="@layout/widget_page_haberler" />
    </FrameLayout>

</LinearLayout>
