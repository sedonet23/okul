<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Başlık satırı: Okul adı + Tarih -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_okul_adi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Okul Yönetim Paneli"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_tarih"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8212;"
            android:textColor="#CCE8E8"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Ince ayraç -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="6dp" />

    <!-- NÖBET -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOBET"
            android:textColor="#ABDEDE"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_nobet_icerik"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="&#8212;"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- ZİL SAYACI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#22FFFFFF"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_zil_icerik"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#8212;"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- DERSLER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DERSLER"
            android:textColor="#ABDEDE"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_ders_icerik"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="&#8212;"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- YAKLAŞAN BELGELER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BELGELER"
            android:textColor="#ABDEDE"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_belge_icerik"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="&#8212;"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- Ince ayraç -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="6dp" />

    <!-- NOT EKLE butonu -->
    <TextView
        android:id="@+id/widget_not_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Not Ekle"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#33FFFFFF"
        android:paddingTop="5dp"
        android:paddingBottom="5dp" />

</LinearLayout>
