<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/widget_okul_adi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Okul Y&#246;netim Paneli"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_tarih"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8212;"
            android:textColor="#CCE8E8"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#128737; BUG&#220;N N&#214;BET"
        android:textColor="#ABDEDE"
        android:textSize="8sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_nobet_icerik"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="N&#246;bet verisi yok.\nUygulamay&#305; a&#231;&#305;n&#305;z."
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/widget_zil_icerik"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#128276; &#8212;"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#128197; BUG&#220;N DERSLER"
        android:textColor="#ABDEDE"
        android:textSize="8sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_ders_icerik"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ders program&#305; yok.\nUygulamay&#305; a&#231;&#305;n&#305;z."
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#128203; YAKLA&#350;AN BELGELER"
        android:textColor="#ABDEDE"
        android:textSize="8sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_belge_icerik"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#8212;"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/widget_not_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="&#9999;&#65039;  Not Ekle"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#33FFFFFF"
        android:paddingTop="5dp"
        android:paddingBottom="5dp" />

</LinearLayout>
